<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <PackageType>Template</PackageType>
    <PackageId>STS2.RitsuLib.ModTemplate</PackageId>
    <PackageVersion>1.0.2</PackageVersion>
    <Title>RitsuLib Mod Template</Title>
    <Authors>Nothing</Authors>
    <Description>A dotnet new template for creating Slay the Spire 2 mods built on RitsuLib.</Description>
    <PackageTags>dotnet-new;templates;sts2;ritsulib;godot;mod</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <PackageOutputPath Condition="'$(PackageOutputPath)' == ''">$(MSBuildProjectDirectory)\bin\$(Configuration)</PackageOutputPath>
    <LocalTemplatePackagePath Condition="'$(LocalTemplatePackagePath)' == ''">$(PackageOutputPath)\$(PackageId).$(PackageVersion).nupkg</LocalTemplatePackagePath>
    <InstallTemplateOnPack Condition="'$(InstallTemplateOnPack)' == ''">true</InstallTemplateOnPack>
    <PublishTemplateOnPack Condition="'$(PublishTemplateOnPack)' == ''">false</PublishTemplateOnPack>
    <NuGetPushSource Condition="'$(NuGetPushSource)' == ''">https://api.nuget.org/v3/index.json</NuGetPushSource>
    <NuGetApiKey Condition="'$(NuGetApiKey)' == ''">$(NUGET_API_KEY)</NuGetApiKey>
    <NuGetPushTimeoutSeconds Condition="'$(NuGetPushTimeoutSeconds)' == ''">300</NuGetPushTimeoutSeconds>
    <AllowNonReleaseNuGetPublish Condition="'$(AllowNonReleaseNuGetPublish)' == ''">false</AllowNonReleaseNuGetPublish>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="RitsuLibModTemplate\**\*"
             Exclude="RitsuLibModTemplate\.git\**;RitsuLibModTemplate\.godot\**;RitsuLibModTemplate\.idea\**;RitsuLibModTemplate\.vs\**;RitsuLibModTemplate\bin\**;RitsuLibModTemplate\obj\**;RitsuLibModTemplate\local.props;RitsuLibModTemplate\**\*.user;RitsuLibModTemplate\**\*.suo;RitsuLibModTemplate\**\*.uid;RitsuLibModTemplate\**\*.import" />
    <None Include="RitsuLibModTemplate\README.md" Pack="true" PackagePath="" Link="README.md" />
    <None Include="RitsuLibModTemplate\README.en.md" Pack="true" PackagePath="" Link="README.en.md" />
  </ItemGroup>

  <Target Name="_InstallTemplatePackage">
    <Message Importance="High" Text="Installing local template package: $(LocalTemplatePackagePath)" />
    <Exec Command="dotnet new uninstall &quot;$(PackageId)&quot;" IgnoreExitCode="true" />
    <Exec Command="dotnet new install &quot;$(LocalTemplatePackagePath)&quot;" />
  </Target>

  <Target Name="InstallTemplate" DependsOnTargets="Pack;_InstallTemplatePackage" />

  <Target Name="InstallTemplateAfterPack"
          AfterTargets="Pack"
          DependsOnTargets="_InstallTemplatePackage"
          Condition="'$(InstallTemplateOnPack)' == 'true'" />

  <Target Name="_ValidateNuGetPublishPackage">
    <Error Condition="'$(NuGetApiKey)' == ''"
           Text="NuGetApiKey is required to publish. Set the NUGET_API_KEY environment variable or pass /p:NuGetApiKey=*** from Rider." />
    <Error Condition="'$(Configuration)' != 'Release' and '$(AllowNonReleaseNuGetPublish)' != 'true'"
           Text="Publishing to nuget.org requires -c Release. Pass /p:AllowNonReleaseNuGetPublish=true only for intentional test feeds." />
    <Error Condition="!Exists('$(LocalTemplatePackagePath)')"
           Text="Package file was not found: $(LocalTemplatePackagePath)" />
  </Target>

  <Target Name="_PublishTemplatePackage" DependsOnTargets="_ValidateNuGetPublishPackage">
    <Message Importance="High" Text="Publishing $(LocalTemplatePackagePath) to $(NuGetPushSource)" />
    <Exec EchoOff="true"
          Command="dotnet nuget push &quot;$(LocalTemplatePackagePath)&quot; --api-key &quot;$(NuGetApiKey)&quot; --source &quot;$(NuGetPushSource)&quot; --timeout &quot;$(NuGetPushTimeoutSeconds)&quot; --skip-duplicate --no-symbols" />
  </Target>

  <Target Name="PublishTemplateToNuGet" DependsOnTargets="Pack;_PublishTemplatePackage" />

  <Target Name="PublishTemplateAfterPack"
          AfterTargets="Pack"
          DependsOnTargets="_PublishTemplatePackage"
          Condition="'$(PublishTemplateOnPack)' == 'true'" />
</Project>
