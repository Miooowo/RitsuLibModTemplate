{
  "$schema": "http://json.schemastore.org/template",
  "author": "Nothing",
  "classifications": [
    "STS2",
    "RitsuLib",
    "Mod",
    "Godot"
  ],
  "identity": "Miooowo.STS2.RitsuLib.ModTemplate.CSharp",
  "groupIdentity": "Miooowo.STS2.RitsuLib.ModTemplate",
  "name": "Miooowo RitsuLib Mod Template",
  "shortName": "mioooworitsulibmod",
  "sourceName": "RitsuLibModTemplate",
  "preferNameDirectory": true,
  "guids": [
    "66F01E42-8110-4F71-93A7-3BC7A8A3B97C"
  ],
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "modIdConstant": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "constantCase",
      "replaces": "RITSU_LIB_MOD_TEMPLATE",
      "description": "The template name converted to CONSTANT_CASE for localization keys."
    }
  },
  "forms": {
    "splitBeforeCapitals": {
      "identifier": "replace",
      "pattern": "([a-z0-9])([A-Z])",
      "replacement": "$1_$2"
    },
    "nonAlphaNumericToUnderscore": {
      "identifier": "replace",
      "pattern": "[^A-Za-z0-9]+",
      "replacement": "_"
    },
    "trimUnderscores": {
      "identifier": "replace",
      "pattern": "^_+|_+$",
      "replacement": ""
    },
    "upperInvariant": {
      "identifier": "upperCaseInvariant"
    },
    "constantCase": {
      "identifier": "chain",
      "steps": [
        "splitBeforeCapitals",
        "nonAlphaNumericToUnderscore",
        "trimUnderscores",
        "upperInvariant"
      ]
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            ".git/**",
            ".godot/**",
            ".idea/**",
            ".vs/**",
            "bin/**",
            "obj/**",
            "local.props",
            "*.user",
            "*.suo",
            "**/*.uid",
            "**/*.import"
          ]
        }
      ]
    }
  ]
}
